#!/usr/bin/env python3
"""Keep one secret in a short-lived process and expose it over a local socket."""

from __future__ import annotations

import argparse
import getpass
import json
import os
import re
import select
import signal
import socket
import subprocess
import sys
import threading
import time
from pathlib import Path
from typing import Any


NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$")
SESSION_ROOT = Path(os.environ.get("TMPDIR", "/tmp")) / "secret-manager-sessions"


def die(message: str, code: int = 1) -> int:
    print(message, file=sys.stderr)
    return code


def validate_name(name: str) -> None:
    if not NAME_RE.fullmatch(name):
        raise ValueError("--name must contain only letters, numbers, '.', '_' or '-'.")


def validate_env_name(name: str) -> None:
    if not re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", name):
        raise ValueError("--env must be a valid environment variable name.")


def format_ttl(ttl: int) -> str:
    if ttl % 3600 == 0:
        return f"{ttl // 3600}時間後に自動失効"
    if ttl % 60 == 0:
        return f"{ttl // 60}分後に自動失効"
    return f"{ttl}秒後に自動失効"


def render_panel(args: argparse.Namespace) -> None:
    print("\n**************************************************")
    print("  Secret Manager")
    print("**************************************************")
    print("  Key Type : 一時的（セッション）")
    print("  保存先   : なし（プロセスのメモリのみ）")
    print(f"  有効期限 : {format_ttl(args.ttl)}")
    print(f"  Secret   : {args.env}")
    print(f"  Session  : {args.name}")
    print("  用途     : 同一セッション内の複数コマンドで再利用")
    print("\n  上記を確認してから、Terminal内の value 欄に入力してください。\n")


def session_dir(name: str) -> Path:
    validate_name(name)
    return SESSION_ROOT / name


def send_request(name: str, request: dict[str, Any]) -> dict[str, Any]:
    path = session_dir(name) / "socket"
    if not path.exists():
        raise RuntimeError(f"Session not found: {name}")
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(30)
        try:
            client.connect(str(path))
        except OSError as exc:
            raise RuntimeError(f"Session is no longer available: {name}") from exc
        client.sendall(json.dumps(request, separators=(",", ":")).encode() + b"\n")
        chunks = []
        while True:
            chunk = client.recv(65536)
            if not chunk:
                break
            chunks.append(chunk)
    return json.loads(b"".join(chunks).decode())


def run_exec(name: str, command: list[str]) -> int:
    if not command:
        return die("Usage: secret-session exec --name NAME -- <command> [args...]", 2)
    try:
        response = send_request(name, {"op": "exec", "argv": command, "cwd": str(Path.cwd())})
    except (OSError, RuntimeError, json.JSONDecodeError) as exc:
        return die(str(exc))
    if response.get("stdout"):
        sys.stdout.write(response["stdout"])
    if response.get("stderr"):
        sys.stderr.write(response["stderr"])
    return int(response.get("code", 1))


def run_clear(name: str) -> int:
    try:
        response = send_request(name, {"op": "clear"})
    except (OSError, RuntimeError, json.JSONDecodeError) as exc:
        return die(str(exc))
    if not response.get("ok"):
        return die("Could not clear session.")
    print(f"[Secret Manager] Cleared session: {name}")
    return 0


def serve(name: str, env_name: str, secret: str, ttl: int) -> int:
    directory = session_dir(name)
    try:
        SESSION_ROOT.mkdir(mode=0o700, parents=True, exist_ok=True)
        os.chmod(SESSION_ROOT, 0o700)
        directory.mkdir(mode=0o700)
        os.chmod(directory, 0o700)
    except FileExistsError:
        return die(f"Session already exists: {name}. Clear it or choose another name.")
    socket_path = directory / "socket"
    environment = os.environ.copy()
    environment[env_name] = secret
    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    if threading.current_thread() is threading.main_thread():
        signal.signal(signal.SIGTERM, lambda _signum, _frame: raise_system_exit())
        signal.signal(signal.SIGHUP, lambda _signum, _frame: raise_system_exit())
    try:
        server.bind(str(socket_path))
        os.chmod(socket_path, 0o600)
        server.listen(1)
        deadline = time.monotonic() + ttl
        print(f"[Secret Manager] Session active: {name} (TTL {ttl}s)", flush=True)
        while True:
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                print(f"[Secret Manager] Session expired: {name}", flush=True)
                return 0
            readable, _, _ = select.select([server], [], [], remaining)
            if not readable:
                print(f"[Secret Manager] Session expired: {name}", flush=True)
                return 0
            connection, _ = server.accept()
            with connection:
                connection.settimeout(30)
                request = json.loads(connection.makefile("rb").readline().decode())
                if request.get("op") == "clear":
                    connection.sendall(b'{"ok":true}\n')
                    return 0
                if request.get("op") != "exec":
                    connection.sendall(b'{"ok":false,"code":2}\n')
                    continue
                argv = request.get("argv")
                cwd = request.get("cwd")
                if not isinstance(argv, list) or not argv or not all(isinstance(item, str) for item in argv):
                    connection.sendall(b'{"ok":false,"code":2,"stderr":"Invalid command.\\n"}\n')
                    continue
                if not isinstance(cwd, str) or not os.path.isdir(cwd):
                    connection.sendall(b'{"ok":false,"code":2,"stderr":"Working directory not found.\\n"}\n')
                    continue
                try:
                    completed = subprocess.run(
                        argv,
                        cwd=cwd,
                        env=environment,
                        capture_output=True,
                        text=True,
                        errors="replace",
                        timeout=max(0.1, deadline - time.monotonic()),
                        check=False,
                    )
                except subprocess.TimeoutExpired as exc:
                    timeout_stdout = exc.stdout.decode(errors="replace") if isinstance(exc.stdout, bytes) else (exc.stdout or "")
                    timeout_stderr = exc.stderr.decode(errors="replace") if isinstance(exc.stderr, bytes) else (exc.stderr or "")
                    response = {
                        "ok": False,
                        "code": 124,
                        "stdout": timeout_stdout,
                        "stderr": timeout_stderr + "[Secret Manager] Session TTL expired.\n",
                    }
                    connection.sendall(json.dumps(response, ensure_ascii=False).encode() + b"\n")
                    return 124
                response = {
                    "ok": True,
                    "code": completed.returncode,
                    "stdout": completed.stdout,
                    "stderr": completed.stderr,
                }
                connection.sendall(json.dumps(response, ensure_ascii=False).encode() + b"\n")
    finally:
        server.close()
        try:
            socket_path.unlink()
        except FileNotFoundError:
            pass
        try:
            directory.rmdir()
        except OSError:
            pass
        environment.pop(env_name, None)


def raise_system_exit() -> None:
    raise SystemExit(0)


def run_start(args: argparse.Namespace) -> int:
    try:
        validate_name(args.name)
        validate_env_name(args.env)
    except ValueError as exc:
        return die(str(exc), 2)
    if args.ttl < 60:
        return die("--ttl must be at least 60 seconds.", 2)
    if not args.foreground and not (sys.stdin.isatty() and sys.stdout.isatty()):
        terminal = Path(__file__).with_name("open-secret-terminal.sh")
        command = [sys.executable, str(Path(__file__).resolve()), "start", "--foreground"]
        command.extend(sys.argv[2:])
        result = subprocess.call(
            [
                str(terminal),
                "--cwd",
                str(Path.cwd()),
                "--key-type",
                "一時的（セッション）",
                "--storage",
                "なし（プロセスのメモリのみ）",
                "--ttl",
                str(args.ttl),
                "--secret-name",
                args.env,
                "--purpose",
                "同一セッション内の複数コマンドで再利用",
                "--",
                *command,
            ]
        )
        if result != 0:
            return result
        ready_path = session_dir(args.name) / "socket"
        deadline = time.monotonic() + 600
        while time.monotonic() < deadline:
            if ready_path.exists():
                print(f"[Secret Manager] Session ready: {args.name}")
                return 0
            time.sleep(0.2)
        return die("Timed out waiting for the session input.", 124)
    if os.environ.get("SECRET_MANAGER_UI_SHOWN") != "1":
        render_panel(args)
    try:
        secret = getpass.getpass("value: ") if args.hidden else input("value: ")
    except (EOFError, KeyboardInterrupt):
        return die("Input cancelled.")
    if not secret:
        return die("No value entered.")
    return serve(args.name, args.env, secret, args.ttl)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="secret-session")
    subparsers = parser.add_subparsers(dest="operation", required=True)
    start = subparsers.add_parser("start", help="start a memory-only secret session")
    start.add_argument("--name", required=True)
    start.add_argument("--env", required=True)
    start.add_argument("--ttl", type=int, default=3600)
    start.add_argument("--hidden", action="store_true")
    start.add_argument("--foreground", action="store_true", help=argparse.SUPPRESS)
    execute = subparsers.add_parser("exec", help="run a command in a session")
    execute.add_argument("--name", required=True)
    execute.add_argument("command", nargs=argparse.REMAINDER)
    clear = subparsers.add_parser("clear", help="clear a session")
    clear.add_argument("--name", required=True)
    return parser


def main() -> int:
    args = build_parser().parse_args()
    if args.operation == "start":
        return run_start(args)
    if args.operation == "exec":
        return run_exec(args.name, args.command[1:] if args.command[:1] == ["--"] else args.command)
    return run_clear(args.name)


if __name__ == "__main__":
    raise SystemExit(main())
